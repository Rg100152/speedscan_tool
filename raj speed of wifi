    def update_quality(self, signal, ping, speed):
        """Update quality indicator based on results"""
        if speed and ping:
            if speed > 50 and ping < 50:
                quality = "Excellent! 🌟"
                emoji = "⚡⚡⚡"
                color = "#4CAF50"
            elif speed > 25 and ping < 100:
