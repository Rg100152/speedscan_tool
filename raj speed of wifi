        outer_frame.grid(row=row, column=col, columnspan=columnspan, 
                        padx=10, pady=10, sticky='nsew')
        
        # Inner frame
        inner_frame = tk.Frame(
            outer_frame,
            bg=self.colors['white'],
            padx=10,
            pady=10
        )
        inner_frame.pack(fill=tk.BOTH, expand=True)
        
        # Title
        title_label = tk.Label(
