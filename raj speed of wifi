        content_frame.pack(fill=tk.BOTH, expand=True)
        
        return content_frame
    
    def start_scan_thread(self):
        """Start scan in separate thread to prevent GUI freezing"""
        self.scan_button.config(state=tk.DISABLED, text="⏳ Scanning...")
        self.status_var.set("Scanning WiFi network... Please wait.")
        thread = threading.Thread(target=self.scan_network)
        thread.daemon = True
        thread.start()
    
    def scan_network(self):
        """Main scanning function"""
        try:
            # Get WiFi info
            self.root.after(0, self.update_status, "Getting WiFi information...")
            wifi_info = self.get_wifi_info()
            
            if wifi_info:
                self.root.after(0, self.update_wifi_info, wifi_info)
            
            # Ping test
            self.root.after(0, self.update_status, "Testing ping...")
            ping_time = self.ping_test()
            
            if ping_time:
                self.root.after(0, self.update_ping, ping_time)
            
            # Download test
            self.root.after(0, self.update_status, "Testing download speed...")
            download_speed = self.download_speed_test()
            
            if download_speed:
                self.root.after(0, self.update_download, download_speed)
            
            # Upload test (simulated for demo)
            self.root.after(0, self.update_status, "Testing upload speed...")
            time.sleep(1)  # Simulate upload test
            upload_speed = download_speed * 0.7 if download_speed else None
            
            if upload_speed:
                self.root.after(0, self.update_upload, upload_speed)
            
            # Update quality
            self.root.after(0, self.update_quality, 
                          wifi_info.get('signal', 0) if wifi_info else 0,
                          ping_time,
                          download_speed)
            
            self.root.after(0, self.update_status, "Scan complete!")
            
        except Exception as e:
            self.root.after(0, self.update_status, f"Error: {str(e)}")
        finally:
            self.root.after(0, self.enable_scan_button)
    
    def get_wifi_info(self):
        """Get WiFi network information"""
        try:
            if self.system == "Windows":
                result = subprocess.run(
                    ['netsh', 'wlan', 'show', 'interfaces'], 
                    capture_output=True, text=True
                )
                output = result.stdout
                
                ssid_match = re.search(r'SSID\s*:\s*(.+)', output)
                signal_match = re.search(r'Signal\s*:\s*(\d+)%', output)
                
                ssid = ssid_match.group(1).strip() if ssid_match else "Not Connected"
                signal = int(signal_match.group(1)) if signal_match else 0
                
                return {'ssid': ssid, 'signal': signal}
                
            else:
                # For Linux/macOS
                return {'ssid': 'Test Network', 'signal': 75}
                
        except:
            return {'ssid': 'Error getting info', 'signal': 0}
    
    def ping_test(self, host="8.8.8.8", count=4):
        """Perform ping test"""
        try:
            if self.system == "Windows":
                param = '-n'
            else:
                param = '-c'
            
            result = subprocess.run(
                ['ping', param, str(count), host], 
                capture_output=True, text=True, timeout=10
            )
            
            times = re.findall(r'time[= ]<?(\d+\.?\d*)', result.stdout.lower())
            
            if times:
                avg_time = sum(float(t) for t in times) / len(times)
                return avg_time
            
        except:
            pass
        return None
    
    def download_speed_test(self):
        """Simulate download speed test"""
        # In real scenario, you'd use speedtest-cli or similar
        # This is a simulation for demo
        import random
        time.sleep(2)  # Simulate test time
        return random.uniform(20, 100)  # Random speed between 20-100 Mbps
    
